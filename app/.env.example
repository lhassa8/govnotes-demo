# Govnotes app — local development environment
#
# Copy this file to .env and fill in the blanks. Do not commit .env.
# In production these are injected via the ECS task definition from
# Secrets Manager.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Postgres connection string. For local dev, point at the docker-compose
# pg instance or a local install.
DATABASE_URL=postgres://govnotes_app:CHANGE_ME@localhost:5432/govnotes

# JWT signing key. Generate with `openssl rand -hex 48`. In production
# this is sourced from Secrets Manager; do NOT use the dev value for
# any deployed environment.
JWT_SIGNING_KEY=REPLACE_WITH_LOCAL_DEV_SECRET

# Short-lived access token TTL, in seconds.
JWT_ACCESS_TTL=900

# S3 bucket for user attachments. Blank locally — uploads are stubbed.
USER_UPLOADS_BUCKET=

# AWS region, used when generating presigned URLs in production.
AWS_REGION=us-east-1
